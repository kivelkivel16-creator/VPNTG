# Скопируй этот файл в .env и заполни своими значениями
# cp .env.example .env
# .env НЕ коммитится в git (уже в .gitignore)

# GitHub Personal Access Token (repo scope)
# https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# Firebase Database Secret
# Firebase Console → Project Settings → Service accounts → Database secrets
FIREBASE_SECRET=...
